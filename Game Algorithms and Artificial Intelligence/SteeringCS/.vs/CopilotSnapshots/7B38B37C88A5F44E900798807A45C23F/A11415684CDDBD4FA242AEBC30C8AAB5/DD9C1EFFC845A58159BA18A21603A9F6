using System;
using System.Collections.Generic;
using System.Drawing;
using SteeringCS.entity;
using SteeringCS.util;
using SteeringCS.world;

namespace SteeringCS.behaviours
{
    /// <summary>
    /// Steers entities away from obstacles in their path.
    /// Creates smooth arcs around obstacles by detecting them ahead of time
    /// and applying lateral steering forces.
    /// </summary>
    public class ObstacleAvoidance_Behaviour : Steering_Behaviour
    {
        /// <summary>
        /// Base detection distance in front of the entity.
        /// The actual detection range grows dynamically with the entity's speed.
        /// </summary>
        public double DetectionBoxLength { get; set; } = 100;

        public ObstacleAvoidance_Behaviour(Entity owner) : base(owner)
        {
        }

        public override Vector_2D Calculate()
        {
            // Early exit if no world or obstacles exist
            if (Owner.MyWorld == null || Owner.MyWorld.Objects == null)
                return new Vector_2D(0, 0);

            // Calculate detection range that grows with speed
            // Faster entities look further ahead to react earlier
            double dynamicLength = DetectionBoxLength +
                (Owner.Velocity.Length() / Owner.MaxVelocity) * DetectionBoxLength;

            // Track the closest threatening obstacle
            WorldObject closestObstacle = null;
            double closestDistance = double.MaxValue;
            Vector_2D closestObstaclePos = null;

            // Check each obstacle in the world
            foreach (var obstacle in Owner.MyWorld.Objects)
            {
                // Vector from entity to obstacle
                Vector_2D toObstacle = Vector_2D.Subtract(obstacle.Position, Owner.Position);
                double distance = toObstacle.Length();

                // Skip obstacles that are too far away
                if (distance > dynamicLength + obstacle.Radius)
                    continue;

                // Get normalized direction the entity is facing
                Vector_2D direction = Owner.Direction.Clone().Scale_to_Length(1);

                // Project obstacle position onto the entity's forward path
                // This tells us how far ahead the obstacle is
                double projection = toObstacle.X * direction.X + toObstacle.Y * direction.Y;

                // Skip obstacles behind us
                if (projection <= 0)
                    continue;

                // Skip obstacles beyond our detection range
                if (projection > dynamicLength)
                    continue;

                // Find the closest point on our forward path to the obstacle
                Vector_2D projectedPoint = Vector_2D.Multiply(direction, projection);
                Vector_2D closestPointOnPath = Vector_2D.Add(Owner.Position, projectedPoint);

                // Calculate how close the obstacle is to our path
                double distanceToPath = Vector_2D.Distance(obstacle.Position, closestPointOnPath);

                // If obstacle is in our way and closer than previous ones, track it
                if (distanceToPath <= obstacle.Radius + 20 && projection < closestDistance)
                {
                    closestDistance = projection;
                    closestObstacle = obstacle;
                    closestObstaclePos = obstacle.Position;
                }
            }

            // No threatening obstacles found, no avoidance needed
            if (closestObstacle == null)
                return new Vector_2D(0, 0);

            // Calculate the point on our path where we're closest to the obstacle
            Vector_2D ahead = Owner.Direction.Clone().Scale_to_Length(closestDistance);
            Vector_2D closestPoint = Vector_2D.Add(Owner.Position, ahead);

            // Calculate direction to steer away from obstacle
            // This points from the obstacle center to the closest point on our path
            Vector_2D avoidanceDirection = Vector_2D.Subtract(closestPoint, closestObstaclePos);

            // If we're exactly on the obstacle, pick a perpendicular direction
            if (avoidanceDirection.Is_length_zero())
            {
                avoidanceDirection = Owner.Direction.Clone().Rotate_90_degrees_clockwise();
            }
            else
            {
                avoidanceDirection.Normalize();
            }

            // Calculate how strong the avoidance force should be
            // safeDistance: how far we want to stay from obstacles (larger = wider arcs)
            double safeDistance = closestObstacle.Radius + 75;

            // How close is the obstacle to our path? (0 = far, 1 = very close)
            double distanceToPathCenter = Vector_2D.Distance(closestObstaclePos, closestPoint);
            double threatLevel = 1.0 - Math.Min(1.0, distanceToPathCenter / safeDistance);

            // How soon will we reach the obstacle? (0 = far away, 1 = very close)
            double urgency = 1.0 - (closestDistance / dynamicLength);

            // Combine threat and urgency for final force strength
            double forceMultiplier = threatLevel * urgency;

            // Apply the steering force (1.5x multiplier for stronger avoidance)
            Vector_2D steeringForce = Vector_2D.Multiply(avoidanceDirection, forceMultiplier * Owner.MaxVelocity * 1.5);

            return steeringForce;
        }

        public override void Render_for_Debug(Graphics g)
        {
            // Don't draw if entity isn't moving
            if (Owner.Direction.Is_length_zero()) return;

            // Calculate the same detection range used in obstacle detection
            double dynamicLength = DetectionBoxLength +
                (Owner.Velocity.Length() / Owner.MaxVelocity) * DetectionBoxLength;

            // Find where the detection range ends
            Vector_2D endPoint = Owner.Direction.Clone().Scale_to_Length(dynamicLength);
            endPoint.Add(Owner.Position);

            // Draw a yellow dashed line showing the detection range
            using (Pen pen = new Pen(Color.Yellow, 2))
            {
                pen.DashStyle = System.Drawing.Drawing2D.DashStyle.Dash;
                g.DrawLine(pen,
                    (float)Owner.Position.X, (float)Owner.Position.Y,
                    (float)endPoint.X, (float)endPoint.Y);
            }

            // Create the detection box visualization (a rectangle in front of the entity)
            const float boxWidth = 30f;

            // Get a perpendicular vector for the box sides
            Vector_2D side = Owner.Direction.Clone().Rotate_90_degrees_clockwise().Scale_to_Length(boxWidth / 2);

            // Define the four corners of the detection box
            PointF[] detectionBox = new PointF[]
            {
                new PointF((float)(Owner.Position.X + side.X), (float)(Owner.Position.Y + side.Y)),
                new PointF((float)(Owner.Position.X - side.X), (float)(Owner.Position.Y - side.Y)),
                new PointF((float)(endPoint.X - side.X), (float)(endPoint.Y - side.Y)),
                new PointF((float)(endPoint.X + side.X), (float)(endPoint.Y + side.Y))
            };

            // Draw the detection box outline in semi-transparent orange
            using (Pen pen = new Pen(Color.FromArgb(100, Color.Orange), 1))
            {
                g.DrawPolygon(pen, detectionBox);
            }
        }
    }
}